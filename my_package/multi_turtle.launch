<launch>

  <!-- 첫 번째 거북이 (기본 이름) -->
  <group ns="turtlesim1">
    <node pkg="turtlesim" name="sim" type="turtlesim_node"/>
    <!-- 키보드 조작 (turtle1 제어용) -->
    <node pkg="turtlesim" type="turtle_teleop_key" name="teleop" output="screen" />
  </group>
  
  <!-- 두 번째 거북이 기본이름 -->
  <group ns="turtlesim2">
    <node pkg="turtlesim" name="sim" type="turtlesim_node"/>
    
    <node pkg="turtlesim" name="mimic" type="mimic">
      <remap from="/turtle1/cmd_vel" to="/turtle2/cmd_vel" />
    </node>
  </group>


</launch>